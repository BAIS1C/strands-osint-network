# ============================================
# Crucix Intelligence Engine — Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# Keys are optional — sources without keys degrade gracefully.
#
# IMPORTANT: Do NOT put comments on the same line as values.
# Docker env_file treats inline comments as part of the value.

# === OSINT Source API Keys ===

# Federal Reserve Economic Data (free: fred.stlouisfed.org/docs/api)
FRED_API_KEY=
# NASA FIRMS fire data (free: firms.modaps.eosdis.nasa.gov/api)
FIRMS_MAP_KEY=
# Energy Information Administration (free: api.eia.gov/register)
EIA_API_KEY=
# Maritime AIS data (aisstream.io)
AISSTREAM_API_KEY=
# Armed Conflict Location & Event Data (acleddata.com/user/register)
ACLED_EMAIL=
# OAuth2 password grant (API keys deprecated Sept 2025)
ACLED_PASSWORD=

# === Server Configuration ===

# Dashboard server port
PORT=3117
# Auto-refresh interval (minutes)
REFRESH_INTERVAL_MINUTES=15

# === LLM Layer (optional) ===
# Enables AI-enhanced trade ideas, breaking-news alerts, and the /api/chat consigliere.
# Provider options: anthropic | openai | gemini | codex | openrouter | minimax | lmstudio
LLM_PROVIDER=
# Not needed for codex (uses ~/.codex/auth.json) or lmstudio (local, no key required)
LLM_API_KEY=
# Optional override. Each provider has a sensible default:
# anthropic: claude-sonnet-4-6 | openai: gpt-5.4 | gemini: gemini-3.1-pro | codex: gpt-5.3-codex
# openrouter: openrouter/auto | minimax: MiniMax-M2.5
# lmstudio: any string — LM Studio routes to whatever model is currently loaded in the server UI
LLM_MODEL=
# Override endpoint base URL (LM Studio / any OpenAI-compatible server).
# Default for lmstudio: http://localhost:1234/v1
LLM_BASE_URL=

# === Telegram Alerts (optional, requires LLM) ===
# Create a bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# YouTube Data API v3 — free 10,000 units/day at console.cloud.google.com
# Enables 24/7 live news streams (Al Jazeera, DW, Sky, Bloomberg, CNBC, NHK, etc.)
# resolved dynamically to their currently-live video ID per sweep.
YOUTUBE_API_KEY=

# === Globe / 3D Tiles (RECON sprint 2026-04-30) ===

# Google Photorealistic 3D Tiles — free tier at console.cloud.google.com
# Enable the Map Tiles API on your project, then create an API key. With this
# set, the worldview swaps the flat ellipsoid for a photorealistic 3D globe.
# Without it, S.O.N falls back gracefully to ESRI imagery on a flat sphere.
GOOGLE_MAPS_API_KEY=

# Cesium Ion access token — optional, free tier at cesium.com/ion
# Unlocks higher-res world terrain when 3D Tiles isn't enabled.
CESIUM_ION_TOKEN=

# === Aircraft (RECON sprint Section 3.2) ===

# ADS-B Exchange via RapidAPI — free tier covers personal beta. Powers the
# MIL (military aircraft) layer. Without it, MIL renders empty (no error).
# rapidapi.com/adsbx/api/adsbexchange-com1
ADSB_API_KEY=

# === Event Tracker (RECON sprint Section 6) ===
# Geo-anchored events: festivals, club nights, concerts, cultural, sport.

# Eventbrite — free at eventbrite.com/platform
EVENTBRITE_TOKEN=
# Songkick — free at songkick.com/developer
SONGKICK_API_KEY=
# Bandsintown — free at artists.bandsintown.com/support/api-installation
BANDSINTOWN_KEY=
# Ticketmaster Discovery — free at developer.ticketmaster.com
TICKETMASTER_KEY=
# Foursquare Places — free at developer.foursquare.com (venue context)
FOURSQUARE_KEY=

# === Real-Time Traffic (optional, RECON sprint Section 5) ===
# HERE Traffic Flow — free 250k transactions/month at developer.here.com
# Used by RECON corridor query for road traffic on planned journeys.
HERE_API_KEY=
