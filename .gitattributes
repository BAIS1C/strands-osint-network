# Default to auto-detect text files, store with LF in repo, check out native on Windows.
* text=auto

# Explicit text files
*.mjs   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.glsl  text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
